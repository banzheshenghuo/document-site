---
import BaseLayout from '../layouts/BaseLayout.astro'
import SearchBox from '../components/SearchBox.astro'
import DocCard from '../components/DocCard.astro'
import { getCollection } from 'astro:content'

// 获取所有文档
const allDocs = await getCollection('posts')

// 按日期排序
const sortedDocs = allDocs.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0
  return dateB - dateA
})

// 分类文档
const readDocs = sortedDocs.filter(doc => {
  const tags = doc.data.tags || []
  return tags.includes('精读') || tags.includes('解读')
})

const collectDocs = sortedDocs.filter(doc => {
  const tags = doc.data.tags || []
  return tags.includes('收藏') || tags.includes('归档') || tags.includes('书签')
})

// 收集所有标签
const allTags = new Set<string>()
sortedDocs.forEach(doc => {
  (doc.data.tags || []).forEach((t: string) => allTags.add(t))
})

// 构建搜索索引
const searchIndex = sortedDocs.map(doc => ({
  slug: doc.slug,
  title: doc.data.title,
  description: doc.data.description || '',
  tags: (doc.data.tags || []).join(' '),
  date: doc.data.date || ''
}))

// 默认显示全部文档
let activeDocs = sortedDocs
let activeTab = 'all'
---

<BaseLayout>
  <div class="home">
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-orb hero-orb-3"></div>
      </div>
      <div class="hero-content">
        <h1>安昙的知识库</h1>
        <p class="subtitle">探索、学习、分享技术知识</p>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">{sortedDocs.length}</span>
            <span class="stat-label">篇文章</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">{allTags.size}</span>
            <span class="stat-label">个标签</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">{readDocs.length}</span>
            <span class="stat-label">篇精读</span>
          </div>
        </div>
      </div>
    </section>

    <SearchBox />

    <section class="docs-section">
      <h2 class="section-title">
        <div class="tabs-container">
          <button
            class={`tab-button ${activeTab === 'all' ? 'active' : ''}`}
            id="tab-all"
            onclick="switchTab('all')"
          >
            全部 <span class="tab-count">({sortedDocs.length})</span>
          </button>
          <button
            class={`tab-button ${activeTab === 'read' ? 'active' : ''}`}
            id="tab-read"
            onclick="switchTab('read')"
          >
            精读 <span class="tab-count">({readDocs.length})</span>
          </button>
          <button
            class={`tab-button ${activeTab === 'collect' ? 'active' : ''}`}
            id="tab-collect"
            onclick="switchTab('collect')"
          >
            收藏 <span class="tab-count">({collectDocs.length})</span>
          </button>
          <button
            class={`tab-button ${activeTab === 'today' ? 'active' : ''}`}
            id="tab-today"
            onclick="switchTab('today')"
          >
            今天 <span class="tab-count" id="today-count">(0)</span>
          </button>
        </div>
      </h2>

      <div class="docs-grid">
        {activeDocs.map(doc => (
          <DocCard
            slug={doc.slug}
            title={doc.data.title}
            description={doc.data.description}
            date={doc.data.date}
            tags={doc.data.tags}
            data-tags={JSON.stringify(doc.data.tags || [])}
          />
        ))}
      </div>

      {activeDocs.length === 0 && (
        <div class="empty-state">
          {activeTab === 'read' && <p>暂无精读文章</p>}
          {activeTab === 'collect' && <p>暂无收藏文章</p>}
          {activeTab === 'today' && <p>今天还没有添加新文章</p>}
          {activeTab === 'all' && <p>暂无文档，请在 <code>src/content/posts</code> 目录下添加 Markdown 文件。</p>}
        </div>
      )}

      <div class="load-more-wrap" id="loadMoreWrap" style="display:none;">
        <button class="load-more-btn" id="loadMoreBtn">加载更多</button>
      </div>
    </section>
  </div>

  <script is:inline>
    const PAGE_SIZE = 18
    const now = new Date()
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate())

    let activeTab = 'all'
    let visibleCount = PAGE_SIZE

    // 动态计算"今天"的文章数量
    function updateTodayCount() {
      const allCards = document.querySelectorAll('.doc-card')
      let count = 0
      allCards.forEach(card => {
        const cardTime = card.getAttribute('data-date') || ''
        if (cardTime) {
          const cardDate = new Date(cardTime)
          const cardDay = new Date(cardDate.getFullYear(), cardDate.getMonth(), cardDate.getDate())
          if (cardDay.getTime() === today.getTime()) count++
        }
      })
      const el = document.getElementById('today-count')
      if (el) el.textContent = `(${count})`
    }
    updateTodayCount()

    // 判断卡片是否匹配当前 tab
    function cardMatchesTab(card, tab) {
      const tagsData = card.getAttribute('data-tags')
      const tags = tagsData ? JSON.parse(tagsData) : []
      switch (tab) {
        case 'read':
          return tags.includes('精读') || tags.includes('解读')
        case 'collect':
          return tags.includes('收藏') || tags.includes('归档') || tags.includes('书签')
        case 'today':
          const cardTime = card.getAttribute('data-date') || ''
          if (!cardTime) return false
          const cardDate = new Date(cardTime)
          const cardDay = new Date(cardDate.getFullYear(), cardDate.getMonth(), cardDate.getDate())
          return cardDay.getTime() === today.getTime()
        default:
          return true
      }
    }

    function switchTab(tab) {
      activeTab = tab
      visibleCount = PAGE_SIZE
      updateTabButtons()
      updateDocGrid()
    }

    function updateTabButtons() {
      document.querySelectorAll('.tab-button').forEach(btn => {
        const tab = btn.id.replace('tab-', '')
        btn.classList.toggle('active', tab === activeTab)
      })
    }

    function updateDocGrid() {
      const emptyState = document.querySelector('.empty-state')
      const loadMoreWrap = document.getElementById('loadMoreWrap')
      if (emptyState) emptyState.style.display = 'none'

      const allCards = document.querySelectorAll('.doc-card')
      let matchIndex = 0

      allCards.forEach(card => {
        if (cardMatchesTab(card, activeTab)) {
          if (matchIndex < visibleCount) {
            card.style.display = ''
            observeCard(card)
          } else {
            card.style.display = 'none'
          }
          matchIndex++
        } else {
          card.style.display = 'none'
        }
      })

      // 空状态
      if (matchIndex === 0 && emptyState) {
        emptyState.style.display = 'block'
        const p = emptyState.querySelector('p')
        if (p) {
          const msgs = { read: '暂无精读文章', collect: '暂无收藏文章', today: '今天还没有添加新文章' }
          p.textContent = msgs[activeTab] || '暂无文档'
        }
      }

      // 加载更多按钮
      if (loadMoreWrap) {
        const hasMore = matchIndex > visibleCount
        loadMoreWrap.style.display = hasMore ? '' : 'none'
      }
    }

    function loadMore() {
      visibleCount += PAGE_SIZE
      updateDocGrid()
    }

    // 加载更多按钮事件
    document.getElementById('loadMoreBtn')?.addEventListener('click', loadMore)

    // 滚动自动加载
    const scrollSentinel = document.getElementById('loadMoreWrap')
    if (scrollSentinel) {
      const scrollObserver = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && scrollSentinel.style.display !== 'none') {
          loadMore()
        }
      }, { rootMargin: '200px' })
      scrollObserver.observe(scrollSentinel)
    }

    // 卡片渐入动画
    const cardObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('card-visible')
          cardObserver.unobserve(entry.target)
        }
      })
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' })

    function observeCard(card) {
      if (!card.classList.contains('card-visible')) {
        cardObserver.observe(card)
      }
    }

    // 初始渲染
    updateDocGrid()
  </script>

  <script define:vars={{ searchIndex, activeDocs: sortedDocs }}>
    window.__SEARCH_INDEX__ = searchIndex
  </script>
</BaseLayout>

<style>
  .home {
    max-width: 900px;
    margin: 0 auto;
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    text-align: center;
    padding: 4rem 0 2.5rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: -40%;
    pointer-events: none;
    z-index: 0;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
    animation: float 20s ease-in-out infinite;
  }

  .hero-orb-1 {
    width: 400px;
    height: 400px;
    background: #3b82f6;
    top: 20%;
    left: 10%;
    animation-delay: 0s;
  }

  .hero-orb-2 {
    width: 350px;
    height: 350px;
    background: #8b5cf6;
    top: 40%;
    right: 15%;
    animation-delay: -7s;
  }

  .hero-orb-3 {
    width: 300px;
    height: 300px;
    background: #06b6d4;
    bottom: 10%;
    left: 40%;
    animation-delay: -14s;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(30px, -20px) scale(1.05); }
    50% { transform: translate(-20px, 20px) scale(0.95); }
    75% { transform: translate(15px, 10px) scale(1.02); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    opacity: 0.8;
  }

  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.75rem 2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .stat-item {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .stat-divider {
    width: 1px;
    height: 20px;
    background: var(--color-border);
  }

  /* ===== Tabs ===== */
  .docs-section {
    margin-top: 2rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tabs-container {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tab-button {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-secondary);
    border-radius: 9999px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.25s;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .tab-button:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(59, 130, 246, 0.05);
  }

  .tab-button.active {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: white;
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
  }

  .tab-count {
    font-size: 0.75rem;
    opacity: 0.85;
  }

  /* ===== Grid ===== */
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  /* 卡片渐入动画 */
  .doc-card {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s ease, transform 0.4s ease, border-color 0.3s, box-shadow 0.3s;
  }

  .doc-card.card-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .doc-card:nth-child(1) { transition-delay: 0ms; }
  .doc-card:nth-child(2) { transition-delay: 40ms; }
  .doc-card:nth-child(3) { transition-delay: 80ms; }
  .doc-card:nth-child(4) { transition-delay: 120ms; }
  .doc-card:nth-child(5) { transition-delay: 160ms; }
  .doc-card:nth-child(6) { transition-delay: 200ms; }
  .doc-card:nth-child(7) { transition-delay: 240ms; }
  .doc-card:nth-child(8) { transition-delay: 280ms; }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-text-secondary);
  }

  .empty-state code {
    background: var(--color-code-bg);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  /* ===== 加载更多 ===== */
  .load-more-wrap {
    text-align: center;
    padding: 2rem 0 1rem;
  }

  .load-more-btn {
    padding: 0.625rem 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-secondary);
    border-radius: 9999px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.25s;
  }

  .load-more-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(59, 130, 246, 0.05);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3rem 0 2rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-stats {
      gap: 1rem;
      padding: 0.625rem 1.25rem;
    }

    .stat-number {
      font-size: 1.1rem;
    }

    .tabs-container {
      justify-content: center;
    }

    .tab-button {
      padding: 0.375rem 0.75rem;
      font-size: 0.8125rem;
    }

    .docs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
