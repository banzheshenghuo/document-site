---
import BaseLayout from '../layouts/BaseLayout.astro'
import SearchBox from '../components/SearchBox.astro'
import DocCard from '../components/DocCard.astro'
import { getCollection } from 'astro:content'

// 获取所有文档
const allDocs = await getCollection('posts')

// 按日期排序
const sortedDocs = allDocs.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0
  return dateB - dateA
})

// 分类文档
const readDocs = sortedDocs.filter(doc => {
  const tags = doc.data.tags || []
  return tags.includes('精读') || tags.includes('解读')
})

const collectDocs = sortedDocs.filter(doc => {
  const tags = doc.data.tags || []
  return tags.includes('收藏') || tags.includes('归档') || tags.includes('书签')
})

// 今天的文档（24小时内）
const now = new Date()
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate())
const todayDocs = sortedDocs.filter(doc => {
  if (!doc.data.date) return false
  const docDate = new Date(doc.data.date)
  const docToday = new Date(docDate.getFullYear(), docDate.getMonth(), docDate.getDate())
  return docToday.getTime() === today.getTime()
})

// 构建搜索索引
const searchIndex = sortedDocs.map(doc => ({
  slug: doc.slug,
  title: doc.data.title,
  description: doc.data.description || '',
  tags: (doc.data.tags || []).join(' '),
  date: doc.data.date || ''
}))

// 默认显示全部文档
let activeDocs = sortedDocs
let activeTab = 'all'
---

<BaseLayout>
  <div class="home">
    <section class="hero">
      <h1>安昙的知识库</h1>
      <p class="subtitle">探索、学习、分享技术知识</p>
    </section>

    <SearchBox />

    <section class="docs-section">
      <h2 class="section-title">
        <div class="tabs-container">
          <button
            class={`tab-button ${activeTab === 'all' ? 'active' : ''}`}
            id="tab-all"
            onclick="switchTab('all')"
          >
            全部 <span class="tab-count">({sortedDocs.length})</span>
          </button>
          <button
            class={`tab-button ${activeTab === 'read' ? 'active' : ''}`}
            id="tab-read"
            onclick="switchTab('read')"
          >
            📚 精读 <span class="tab-count">({readDocs.length})</span>
          </button>
          <button
            class={`tab-button ${activeTab === 'collect' ? 'active' : ''}`}
            id="tab-collect"
            onclick="switchTab('collect')"
          >
            ⭐ 收藏 <span class="tab-count">({collectDocs.length})</span>
          </button>
          <button
            class={`tab-button ${activeTab === 'today' ? 'active' : ''}`}
            id="tab-today"
            onclick="switchTab('today')"
          >
            📅 今天 <span class="tab-count">({todayDocs.length})</span>
          </button>
        </div>
      </h2>

      <div class="docs-grid">
        {activeDocs.map(doc => (
          <DocCard
            slug={doc.slug}
            title={doc.data.title}
            description={doc.data.description}
            date={doc.data.date}
            tags={doc.data.tags}
            data-tags={JSON.stringify(doc.data.tags || [])}
          />
        ))}
      </div>

      {activeDocs.length === 0 && (
        <div class="empty-state">
          {activeTab === 'read' && <p>暂无精读文章</p>}
          {activeTab === 'collect' && <p>暂无收藏文章</p>}
          {activeTab === 'today' && <p>今天还没有添加新文章</p>}
          {activeTab === 'all' && <p>暂无文档，请在 <code>src/content/posts</code> 目录下添加 Markdown 文件。</p>}
        </div>
      )}
    </section>
  </div>

  <script is:inline>
    // 获取今天的日期
    const now = new Date()
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate())

    // 默认活动标签
    let activeTab = 'all'

    function switchTab(tab) {
      activeTab = tab

      updateTabButtons()
      updateDocGrid()
    }
    
    function updateTabButtons() {
      document.querySelectorAll('.tab-button').forEach(btn => {
        const tab = btn.id.replace('tab-', '')
        if (tab === activeTab) {
          btn.classList.add('active')
        } else {
          btn.classList.remove('active')
        }
      })
    }
    
    function updateDocGrid() {
      const grid = document.querySelector('.docs-grid')
      const emptyState = document.querySelector('.empty-state')
      
      if (activeDocs.length === 0) {
        grid.innerHTML = ''
        if (emptyState) {
          emptyState.style.display = 'block'
          const p = emptyState.querySelector('p')
          if (p) {
            switch (activeTab) {
              case 'read':
                p.textContent = '暂无精读文章'
                break
              case 'collect':
                p.textContent = '暂无收藏文章'
                break
              case 'today':
                p.textContent = '今天还没有添加新文章'
                break
              default:
                p.textContent = '暂无文档，请在 <code>src/content/posts</code> 目录下添加 Markdown 文件。'
            }
          }
        }
        return
      }
      
      if (emptyState) {
        emptyState.style.display = 'none'
      }
      
      const allCards = document.querySelectorAll('.doc-card')

      allCards.forEach(card => {
        // 从 data-tags 属性中获取 tags 数据
        const tagsData = card.getAttribute('data-tags')
        const tags = tagsData ? JSON.parse(tagsData) : []

        let shouldShow = false
        switch (activeTab) {
          case 'read':
            shouldShow = tags.includes('精读') || tags.includes('解读')
            break
          case 'collect':
            shouldShow = tags.includes('收藏') || tags.includes('归档') || tags.includes('书签')
            break
          case 'today':
            const cardTime = card.querySelector('.doc-card-date')?.textContent || ''
            if (!cardTime) {
              shouldShow = false
            } else {
              const cardDate = new Date(cardTime)
              const cardToday = new Date(cardDate.getFullYear(), cardDate.getMonth(), cardDate.getDate())
              shouldShow = cardToday.getTime() === today.getTime()
            }
            break
          default:
            shouldShow = true
        }

        if (shouldShow) {
          card.style.display = 'block'
        } else {
          card.style.display = 'none'
        }
      })
    }
  </script>

  <script define:vars={{ searchIndex, activeDocs: sortedDocs }}>
    window.__SEARCH_INDEX__ = searchIndex
  </script>
</BaseLayout>

<style>
  .home {
    max-width: 900px;
    margin: 0 auto;
  }

  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  .docs-section {
    margin-top: 2rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tabs-container {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tab-button {
    padding: 0.625rem 1.25rem;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: 0.5rem;
    cursor: pointer;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .tab-button:hover {
    border-color: var(--color-primary);
    background: var(--color-bg-secondary);
  }

  .tab-button.active {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: white;
  }

  .tab-count {
    font-size: 0.8125rem;
    opacity: 0.9;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-text-secondary);
  }

  .empty-state code {
    background: var(--color-code-bg);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 2rem;
    }

    .tabs-container {
      justify-content: center;
    }

    .tab-button {
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
    }

    .docs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
