---
import { type CollectionEntry, getCollection } from 'astro:content'
import DocLayout from '../../layouts/DocLayout.astro'
import TableOfContents from '../../components/TableOfContents.astro'

export async function getStaticPaths() {
  const docs = await getCollection('posts')
  return docs.map(doc => ({
    params: { slug: doc.slug },
    props: { doc },
  }))
}

type Props = {
  doc: CollectionEntry<'posts'>
}

const { doc } = Astro.props
const { Content, headings } = await doc.render()

const basePath = (import.meta.env.BASE_URL || '/').replace(/\/$/, '')

// 计算阅读时间（中文约 400 字/分钟）
const wordCount = doc.body ? doc.body.length : 0
const readingTime = Math.max(1, Math.ceil(wordCount / 400))

// 格式化日期
const dateStr = doc.data.date
  ? new Date(doc.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
  : ''
---

<DocLayout title={doc.data.title} description={doc.data.description}>
  <article class="doc-page">
    <!-- 阅读进度条 -->
    <div class="reading-progress" id="readingProgress">
      <div class="reading-progress-bar" id="readingProgressBar"></div>
    </div>

    <div class="doc-main">
      <header class="doc-header">
        <div class="doc-header-top">
          <a href={basePath} class="doc-back">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
            返回
          </a>
        </div>
        <h1>{doc.data.title}</h1>
        {doc.data.description && (
          <p class="doc-description">{doc.data.description}</p>
        )}
        <div class="doc-meta">
          {dateStr && (
            <div class="meta-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              <time>{dateStr}</time>
            </div>
          )}
          <div class="meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{readingTime} 分钟阅读</span>
          </div>
          {doc.data.tags && doc.data.tags.length > 0 && (
            <div class="doc-tags">
              {doc.data.tags.map(tag => (
                <span class="doc-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <div class="doc-content prose">
        <Content />
      </div>

      <footer class="doc-footer">
        <a href={basePath} class="doc-back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
          返回全部文章
        </a>
      </footer>
    </div>

    <TableOfContents headings={headings} />

    <!-- 回到顶部 -->
    <button class="back-to-top" id="backToTop" aria-label="回到顶部">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
    </button>
  </article>
</DocLayout>

<script is:inline>
  // 阅读进度条
  const progressBar = document.getElementById('readingProgressBar')
  if (progressBar) {
    const updateProgress = () => {
      const scrollTop = window.scrollY
      const docHeight = document.documentElement.scrollHeight - window.innerHeight
      const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0
      progressBar.style.width = `${progress * 100}%`
    }
    window.addEventListener('scroll', updateProgress, { passive: true })
    updateProgress()
  }

  // 回到顶部按钮
  const backToTop = document.getElementById('backToTop')
  if (backToTop) {
    const handleScroll = () => {
      backToTop.classList.toggle('visible', window.scrollY > 400)
    }
    window.addEventListener('scroll', handleScroll, { passive: true })
    handleScroll()
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' })
    })
  }

  // 目录滚动高亮
  const tocLinks = document.querySelectorAll('.toc-nav a')
  const headings = document.querySelectorAll('.doc-content h2, .doc-content h3')

  if (tocLinks.length && headings.length) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id')
          tocLinks.forEach(link => {
            link.classList.toggle('active', link.getAttribute('href') === `#${id}`)
          })
        }
      })
    }, {
      rootMargin: '-80px 0px -60% 0px',
      threshold: 0
    })

    headings.forEach(h => observer.observe(h))
  }
</script>

<style>
  .doc-page {
    margin-top: 1rem;
    position: relative;
  }

  /* ===== 阅读进度条 ===== */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: transparent;
    z-index: 200;
  }

  .reading-progress-bar {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, #3b82f6, #8b5cf6, #06b6d4);
    transition: width 0.1s linear;
    border-radius: 0 2px 2px 0;
  }

  /* ===== 文章头部 ===== */
  .doc-main {
    min-width: 0;
  }

  .doc-header-top {
    margin-bottom: 1rem;
  }

  .doc-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    transition: all 0.2s;
  }

  .doc-back:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(59, 130, 246, 0.05);
  }

  .doc-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .doc-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-text-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .doc-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .doc-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    opacity: 0.8;
  }

  .meta-item svg {
    opacity: 0.6;
  }

  .doc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-left: auto;
  }

  .doc-tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: var(--color-bg-secondary);
    border-radius: 9999px;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    transition: all 0.2s;
  }

  .doc-tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* ===== 文章内容 ===== */
  .doc-content {
    max-width: 100%;
    overflow-x: hidden;
  }

  .doc-content > * {
    max-width: 100%;
    overflow-wrap: break-word;
  }

  .doc-content h2 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
    font-size: 1.625rem;
    font-weight: 700;
  }

  .doc-content h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.3rem;
    font-weight: 600;
  }

  .doc-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .doc-content ul,
  .doc-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.75rem;
  }

  .doc-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .doc-content a {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    color: var(--color-primary);
  }

  .doc-content a:hover {
    text-decoration-thickness: 2px;
  }

  .doc-content pre {
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow-x: auto;
    max-width: 100%;
    margin: 1.5rem 0;
  }

  .doc-content pre code {
    display: block;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* ===== 文章底部 ===== */
  .doc-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .doc-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s;
  }

  .doc-back-link:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(59, 130, 246, 0.05);
  }

  /* ===== 回到顶部 ===== */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 2.75rem;
    height: 2.75rem;
    background: var(--color-bg);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .back-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .back-to-top:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    box-shadow: 0 4px 16px rgba(59, 130, 246, 0.15);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .doc-header h1 {
      font-size: 1.5rem;
    }

    .doc-content h2 {
      font-size: 1.375rem;
    }

    .doc-content h3 {
      font-size: 1.125rem;
    }

    .back-to-top {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 2.5rem;
      height: 2.5rem;
    }

    .doc-tags {
      margin-left: 0;
    }
  }
</style>
