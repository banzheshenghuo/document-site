---
interface Props {
  headings: { depth: number; text: string; slug: string }[]
}

const { headings } = Astro.props

// 过滤出 h2 和 h3
const tocHeadings = headings.filter(h => h.depth <= 3)
---

{tocHeadings.length > 0 && (
  <aside class="toc" id="toc-sidebar">
    <button class="toc-toggle" id="toc-toggle" aria-label="展开目录">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      <span>目录</span>
      <span class="toc-count">{tocHeadings.length}</span>
      <svg class="toc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
    </button>
    <nav class="toc-nav" id="toc-nav">
      <ul>
        {tocHeadings.map(heading => (
          <li style={`--depth: ${heading.depth - 1}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script is:inline>
  // 移动端目录折叠/展开
  const tocToggle = document.getElementById('toc-toggle')
  const tocNav = document.getElementById('toc-nav')
  const tocSidebar = document.getElementById('toc-sidebar')

  if (tocToggle && tocNav && tocSidebar) {
    tocToggle.addEventListener('click', () => {
      const isOpen = tocSidebar.classList.toggle('toc-open')
      tocToggle.setAttribute('aria-label', isOpen ? '收起目录' : '展开目录')
    })

    // 点击目录链接后自动收起（移动端）
    tocNav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          tocSidebar.classList.remove('toc-open')
        }
      })
    })
  }
</script>

<style>
  .toc {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    padding: 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: box-shadow 0.3s;
  }

  .toc:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
  }

  .toc::-webkit-scrollbar {
    width: 3px;
  }
  .toc::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 3px;
  }

  .toc-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0;
  }

  .toc-toggle svg:first-child {
    opacity: 0.5;
  }

  .toc-count {
    font-size: 0.6875rem;
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    padding: 0 0.375rem;
    border-radius: 9999px;
    font-weight: 500;
  }

  .toc-chevron {
    display: none;
    margin-left: auto;
    transition: transform 0.2s;
  }

  .toc-nav {
    margin-top: 0.75rem;
  }

  .toc-nav ul {
    list-style: none;
  }

  .toc-nav li {
    --depth: 0;
    padding-left: calc(var(--depth) * 0.75rem);
  }

  .toc-nav a {
    display: block;
    padding: 0.3rem 0;
    padding-left: 0.75rem;
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    line-height: 1.5;
    border-left: 2px solid var(--color-border);
    transition: all 0.2s;
  }

  .toc-nav a:hover {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
  }

  .toc-nav a.active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    font-weight: 500;
    background: rgba(59, 130, 246, 0.05);
    border-radius: 0 0.25rem 0.25rem 0;
  }

  /* ===== 移动端：折叠模式 ===== */
  @media (max-width: 768px) {
    .toc {
      position: static;
      max-height: none;
      overflow: visible;
    }

    .toc-chevron {
      display: block;
    }

    .toc-nav {
      display: none;
      margin-top: 0.5rem;
      padding-top: 0.5rem;
      border-top: 1px solid var(--color-border);
    }

    .toc-open .toc-nav {
      display: block;
    }

    .toc-open .toc-chevron {
      transform: rotate(180deg);
    }
  }
</style>
