<div id="search-container" class="search-container">
  <div class="search-box">
    <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/>
      <path d="m21 21-4.3-4.3"/>
    </svg>
    <input
      type="text"
      id="search-input"
      placeholder="搜索文档..."
      autocomplete="off"
    />
    <kbd class="search-shortcut">⌘K</kbd>
  </div>
  <div id="search-results" class="search-results"></div>
</div>

<style is:global>
  .search-container {
    position: relative;
    max-width: 640px;
    margin: 0 auto 2rem;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1rem;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  .search-box:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.08);
  }

  .search-icon {
    color: var(--color-text-secondary);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .search-box:focus-within .search-icon {
    opacity: 0.8;
    color: var(--color-primary);
  }

  .search-box input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .search-box input::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  .search-shortcut {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 2px 8px;
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    font-family: inherit;
    line-height: 1.6;
    letter-spacing: 0.02em;
  }

  /* ===== 搜索结果下拉 ===== */
  .search-results {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.03);
    max-height: 420px;
    overflow-y: auto;
    z-index: 200;
    padding: 6px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
  }

  .search-results.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* 自定义滚动条 */
  .search-results::-webkit-scrollbar {
    width: 6px;
  }
  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }
  .search-results::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 3px;
  }
  .search-results::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-secondary);
  }

  /* ===== 搜索结果项 ===== */
  .search-result-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 12px;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.12s ease;
  }

  .search-result-item:hover,
  .search-result-item.active {
    background: var(--color-bg-secondary);
  }

  .search-result-item-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--color-bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
    color: var(--color-primary);
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .search-result-item:hover .search-result-item-icon {
    opacity: 1;
  }

  .search-result-item-icon svg {
    width: 16px;
    height: 16px;
  }

  .search-result-content {
    flex: 1;
    min-width: 0;
  }

  .search-result-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.5;
    margin-bottom: 2px;
  }

  .search-result-desc {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    opacity: 0.8;
  }

  .search-result-tags {
    display: flex;
    gap: 6px;
    margin-top: 6px;
    flex-wrap: wrap;
  }

  .search-result-tag {
    font-size: 0.6875rem;
    padding: 1px 7px;
    border-radius: 4px;
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    line-height: 1.5;
  }

  .search-result-highlight {
    background: rgba(59, 130, 246, 0.12);
    color: var(--color-primary);
    padding: 1px 3px;
    border-radius: 3px;
    font-weight: 600;
  }

  .search-result-item:hover .search-result-highlight {
    background: rgba(59, 130, 246, 0.18);
  }

  /* ===== 无结果 ===== */
  .search-no-results {
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .search-no-results-icon {
    color: var(--color-text-secondary);
    opacity: 0.3;
    margin-bottom: 8px;
  }

  .search-no-results-text {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  /* ===== 底部提示 ===== */
  .search-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 8px 12px;
    border-top: 1px solid var(--color-border);
    margin-top: 4px;
  }

  .search-footer-hint {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    opacity: 0.5;
  }

  .search-footer-hint kbd {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0 4px;
    font-size: 0.6875rem;
    font-family: inherit;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .search-shortcut {
      display: none;
    }
    .search-results {
      max-height: 320px;
    }
    .search-result-item {
      padding: 8px 10px;
    }
    .search-result-item-icon {
      width: 28px;
      height: 28px;
    }
    .search-footer {
      display: none;
    }
  }
</style>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement
  const searchResults = document.getElementById('search-results') as HTMLDivElement
  let activeIndex = -1

  // 键盘快捷键
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      searchInput.focus()
    }
    if (e.key === 'Escape') {
      searchInput.blur()
      hideResults()
    }

    // 键盘上下选择 & 回车确认
    const items = searchResults.querySelectorAll('.search-result-item')
    if (!items.length || !searchResults.classList.contains('active')) return

    if (e.key === 'ArrowDown') {
      e.preventDefault()
      activeIndex = Math.min(activeIndex + 1, items.length - 1)
      updateActiveItem(items)
    } else if (e.key === 'ArrowUp') {
      e.preventDefault()
      activeIndex = Math.max(activeIndex - 1, 0)
      updateActiveItem(items)
    } else if (e.key === 'Enter' && activeIndex >= 0) {
      e.preventDefault()
      const link = items[activeIndex] as HTMLAnchorElement
      link.click()
    }
  })

  function updateActiveItem(items: NodeListOf<Element>) {
    items.forEach((item, i) => {
      item.classList.toggle('active', i === activeIndex)
    })
  }

  function showResults() {
    searchResults.classList.add('active')
    activeIndex = -1
  }

  function hideResults() {
    searchResults.classList.remove('active')
    activeIndex = -1
  }

  // 搜索功能
  searchInput.addEventListener('input', async () => {
    const query = searchInput.value.trim()

    if (!query) {
      hideResults()
      return
    }

    const index = (window as any).__SEARCH_INDEX__ || []
    const results = performSearch(query, index)
    displayResults(results, query)
  })

  function performSearch(query: string, index: any[]) {
    const terms = query.toLowerCase().split(/\s+/)

    return index
      .map((doc: any) => {
        let score = 0
        const titleLower = doc.title.toLowerCase()
        const descLower = (doc.description || '').toLowerCase()
        const tagsLower = (doc.tags || '').toLowerCase()

        for (const term of terms) {
          if (titleLower.includes(term)) score += 10
          if (tagsLower.includes(term)) score += 5
          if (descLower.includes(term)) score += 2
        }

        return { doc, score }
      })
      .filter(({ score }: any) => score > 0)
      .sort((a: any, b: any) => b.score - a.score)
      .map(({ doc }: any) => doc)
      .slice(0, 8)
  }

  const docIconSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>`

  function displayResults(results: any[], query: string) {
    if (results.length === 0) {
      searchResults.innerHTML = `
        <div class="search-no-results">
          <div class="search-no-results-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
              <path d="M8 11h6"/>
            </svg>
          </div>
          <div class="search-no-results-text">未找到「${escapeHtml(query)}」相关文档</div>
        </div>
      `
      showResults()
      return
    }

    searchResults.innerHTML = results.map(doc => {
      const basePath = document.documentElement.dataset.base || ''
      const tags = (doc.tags || '').split(' ').filter(Boolean)
      const desc = doc.description || ''
      const tagsHtml = tags.length
        ? `<div class="search-result-tags">${tags.slice(0, 3).map((t: string) => `<span class="search-result-tag">${escapeHtml(t)}</span>`).join('')}</div>`
        : ''
      const descHtml = desc
        ? `<div class="search-result-desc">${highlightTerm(escapeHtml(desc), query)}</div>`
        : ''

      return `
        <a href="${basePath}/posts/${doc.slug}" class="search-result-item">
          <div class="search-result-item-icon">${docIconSvg}</div>
          <div class="search-result-content">
            <div class="search-result-title">${highlightTerm(escapeHtml(doc.title), query)}</div>
            ${descHtml}
            ${tagsHtml}
          </div>
        </a>
      `
    }).join('') + `
      <div class="search-footer">
        <span class="search-footer-hint"><kbd>↑</kbd><kbd>↓</kbd> 导航</span>
        <span class="search-footer-hint"><kbd>↵</kbd> 打开</span>
        <span class="search-footer-hint"><kbd>esc</kbd> 关闭</span>
      </div>
    `

    showResults()
  }

  function escapeHtml(text: string) {
    const el = document.createElement('span')
    el.textContent = text
    return el.innerHTML
  }

  function highlightTerm(text: string, term: string) {
    if (!term) return text
    const escaped = term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
    const regex = new RegExp(`(${escaped})`, 'gi')
    return text.replace(regex, '<span class="search-result-highlight">$1</span>')
  }

  // 点击外部关闭搜索结果
  document.addEventListener('click', (e) => {
    const target = e.target as Node
    const container = document.getElementById('search-container')
    if (container && !container.contains(target)) {
      hideResults()
    }
  })
</script>
